PORT=3000
HOST=0.0.0.0
HEADLESS=true
TARGET_URL=https://httpbin.org/ip
NAVIGATION_TIMEOUT_MS=45000

# interval | perRequest
ROTATION_MODE=interval
ROTATION_INTERVAL_MS=120000
TASK_INTERVAL_MS=30000
MAX_RETRIES=3
RETRY_BACKOFF_MS=2000

# Comma-separated values
# Example:
# PROXIES=1.2.3.4:8000:user1:pass1,5.6.7.8:8080:user2:pass2
PROXIES=
# Example:
# ACCOUNTS=account-1,account-2
ACCOUNTS=

LOG_FILE_PATH=./logs/tool-proxy.log

PERSIST_STATE=true
STATE_FILE_PATH=./data/state.json
